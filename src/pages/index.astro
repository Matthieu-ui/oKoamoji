---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE } from "@config";
import SearchBar from "@components/Search";
import dongerData from "../../db/dongers.json";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const shuffleArray = <T,>(array: T[]): T[] => {
  const arr = [...array];
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
};

const shuffledFeatured = shuffleArray(featuredPosts).slice(0, 6);

type DongerMap = Record<string, string[]>;
const dongers = dongerData as DongerMap;

const totalDongers = Object.values(dongers).reduce((sum, arr) => sum + arr.length, 0);
const totalCategories = Object.keys(dongers).length;

const searchList = sortedPosts.map(({ data, slug }) => ({
  title: data.title,
  description: data.description,
  data,
  slug,
}));
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>oKaomoji</h1>
      <p class="tagline">
        {totalDongers.toLocaleString()}+ emoticons across {totalCategories} categories.
        Click any to copy instantly.
      </p>
      <div class="search-wrap">
        <SearchBar searchList={searchList} client:load />
      </div>
    </section>

    <Hr />

    <section id="featured">
      <h2>Browse Categories</h2>
      <ul>
        {
          shuffledFeatured.map(({ data, slug }) => (
            <Card
              client:load
              href={`/posts/${slug}/`}
              frontmatter={data}
              secHeading={false}
            />
          ))
        }
      </ul>
    </section>

    <div class="all-posts-btn-wrapper">
      <LinkButton href="/posts/">All {sortedPosts.length} Categories →</LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #hero {
    @apply pb-6 pt-10;
  }
  #hero h1 {
    @apply my-2 inline-block text-4xl font-semibold sm:text-6xl;
    letter-spacing: -0.03em;
    opacity: 0.85;
  }
  .tagline {
    @apply mt-1 mb-0 text-sm opacity-40 tracking-wide;
  }
  .search-wrap {
    @apply mt-8;
  }
  #featured {
    @apply pb-6 pt-12;
  }
  #featured h2 {
    @apply text-xs font-normal tracking-widest uppercase opacity-40 mb-4;
  }
  .all-posts-btn-wrapper {
    @apply my-10 text-center;
  }
</style>
