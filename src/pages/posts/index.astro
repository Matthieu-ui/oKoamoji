---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Main from "@layouts/Main.astro";
import InfiniteList from "@components/InfiniteList";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE } from "@config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

const postData = sortedPosts.map(({ data, slug }) => ({
  slug,
  title: data.title,
  description: data.description,
}));
---

<Layout title={`Browse | ${SITE.title}`}>
  <Header activeNav="posts" />
  <Main pageTitle="Browse" pageDesc={`${postData.length} categories · ${sortedPosts.reduce((s, p) => s + p.data.description.split("|").length, 0).toLocaleString()}+ emoticons`}>
    <InfiniteList posts={postData} client:load />
  </Main>
  <Footer />
</Layout>
