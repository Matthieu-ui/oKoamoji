---
import DongerGrid from "./DongerGrid";
import dongers from "../../db/dongers.json";

export interface Props {
  flavor: string;
}

const { flavor } = Astro.props;

const categoryDongers: string[] =
  (dongers as Record<string, string[]>)[flavor] ?? [];
---

{
  categoryDongers.length > 0 ? (
    <DongerGrid dongers={categoryDongers} client:load />
  ) : (
    <p class="text-sm opacity-60">No dongers found for "{flavor}".</p>
  )
}
